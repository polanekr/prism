data = np.load('/home/polanekr/Kutatás/PRISM-Framework/examples/results/films/PDD1.npz') # Vagy a te fájlneved
vol = data['volume']
        
# Koordináták kezelése (ha nincsenek elmentve, generáljuk)
if 'z_coords' in data:
    z = data['z_coords']
    y = data['y_coords']
    x = data['x_coords']


plot_3d_interactive(vol, z, y, x, level=30)



